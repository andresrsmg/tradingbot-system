# CONFIGURAÇÃO DO TRADING BOT
# Renomeie para .env e preencha com suas credenciais

# Broker Configuration
BROKER_API_KEY=your_api_key_here
BROKER_API_SECRET=your_api_secret_here
BROKER_BASE_URL=https://paper-api.alpaca.markets  # Para paper trading

# Trading Parameters
SYMBOL=ES  # S&P 500 E-mini futures
INITIAL_CAPITAL=100
STOP_LOSS_PCT=0.005  # 0.5%
TAKE_PROFIT_PCT=0.01  # 1%

# Strategy Parameters
LOOKBACK_PERIOD=20
FAST_MA_PERIOD=5
SLOW_MA_PERIOD=10
MOMENTUM_THRESHOLD=0

# Execution Parameters
CHECK_INTERVAL_SECONDS=30
MAX_POSITION_SIZE=0.1  # 10% do capital por trade

# Logging
LOG_LEVEL=INFO
LOG_FILE=bot.log